# ===== Blog CMS (Super Admin) =====
# MongoDB connection string (Atlas or self-hosted). Without it, the public blog
# serves only the code-defined articles and the CMS shows a config notice.
MONGODB_URI=
# Optional database name (defaults to "brynexlabs")
MONGODB_DB=brynexlabs

# Super-admin login for /super-admin
ADMIN_EMAIL=
ADMIN_PASSWORD=
# Random secret (32+ chars) used to sign the admin session cookie.
# Generate one with: openssl rand -hex 32
ADMIN_SESSION_SECRET=

# ===== Contact form (SMTP) =====
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# ===== Analytics =====
NEXT_PUBLIC_GA_MEASUREMENT_ID=
NEXT_PUBLIC_CLARITY_PROJECT_ID=
NEXT_PUBLIC_META_PIXEL_ID=
NEXT_PUBLIC_GSC_VERIFICATION=
